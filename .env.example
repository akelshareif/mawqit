# Postgres (required for API routes that use the DB)
# Use sslmode=verify-full for hosted Postgres (Neon, etc.) to match pg’s semantics and avoid sslmode deprecation warnings.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=verify-full"

# App
# Canonical URL for share links (set in production, e.g. https://your-app.vercel.app — no trailing slash).
# On Vercel, if unset, the app falls back to https://$VERCEL_URL so *.vercel.app links still work.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cron
CRON_SECRET="generate-a-long-random-string"
CRON_INTERVAL_MINUTES="5"

# Admin (optional)
ADMIN_PASSWORD="dev-only-plaintext"
# ADMIN_PASSWORD_HASH=""
ADMIN_SESSION_SECRET="long-random-string-for-cookie-signing"

# Debug: off in production unless you also set ALLOW_DEBUG_TOOLS_IN_PRODUCTION
ENABLE_DEBUG_TOOLS="false"
# ALLOW_DEBUG_TOOLS_IN_PRODUCTION="false"

# QA reminder clock — shifts time for cron prayer/persistence checks only; expiry uses wall clock
# ENABLE_QA_REMINDER_CLOCK="false"
# Or use ENABLE_DEBUG_TOOLS=true locally without ENABLE_QA_REMINDER_CLOCK
# QA_REMINDER_CLOCK_OFFSET_MINUTES="0"

# Content
LEARN_TO_PRAY_URL="https://example.com/learn-salah"

# Session window
SESSION_VALIDITY_DAYS="30"
SESSION_EXPIRY_WARNING_DAYS="3"

# Email (Resend) — optional; without both, outbound email is mock (message_log only)
# RESEND_API_KEY=""
# RESEND_FROM="Mawqit <noreply@your-verified-domain.com>"
# EMAIL_FORCE_MOCK="false"
# Inbound webhook signing secret (whsec_...) from the Resend webhook endpoint.
# Required for /api/inbound/email to accept Resend's email.received deliveries;
# unset rejects every inbound with 500.
# RESEND_WEBHOOK_SECRET=""

# Web Push — generate keys: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_SUBJECT="mailto:you@example.com"
WEB_PUSH_MODE="mock"

# Public
NEXT_PUBLIC_DONATE_URL=""

# Analytics (optional, server-only)
# PLAUSIBLE_API_KEY=""
# PLAUSIBLE_SITE_ID=""

